{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "predev": "pnpm prisma:ensure-client",
    "dev": "nodemon",
    "prebuild": "pnpm prisma:generate && pnpm prisma:ensure-client",
    "build": "tsc",
    "build:render": "pnpm run build && pnpm run db:deploy",
    "prestart": "pnpm prisma:ensure-client",
    "start": "node dist/server.js",
    "start:render": "pnpm run db:deploy && pnpm run start",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:ensure-client": "node scripts/ensurePrismaClient.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:demo": "tsx scripts/seed-demo.ts",
    "prisma:seed:demo:reset": "tsx scripts/seed-demo.ts --reset",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force && pnpm prisma:seed",
    "db:deploy": "pnpm prisma:generate && prisma migrate deploy && prisma db seed",
    "test:smoke": "tsx scripts/smoke-test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
