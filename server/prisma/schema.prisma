generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_STAKE
  BET_WIN
  REFUND
  BONUS
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum NotificationAudience {
  USER
  ADMIN
}

enum NotificationType {
  DEPOSIT_SUCCESS
  DEPOSIT_FAILED
  SYSTEM
}

model User {
  id            String               @id @default(uuid()) @db.Uuid
  email         String               @unique
  phone         String               @unique
  passwordHash  String               @map("password_hash")
  isVerified    Boolean              @default(false) @map("is_verified")
  role          UserRole             @default(USER)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  wallet        Wallet?
  transactions  WalletTransaction[]
  notifications Notification[]

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid @map("user_id")
  balance     Int      @default(0) @map("balance")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id                       String                 @id @default(uuid()) @db.Uuid
  userId                   String                 @db.Uuid @map("user_id")
  walletId                 String?                @db.Uuid @map("wallet_id")
  type                     WalletTransactionType
  status                   WalletTransactionStatus @default(PENDING)
  amount                   Int
  currency                 String                 @default("KES")
  channel                  String
  reference                String                 @unique
  checkoutRequestId        String?                @unique @map("checkout_request_id")
  merchantRequestId        String?                @unique @map("merchant_request_id")
  phone                    String?                @map("phone")
  accountReference         String?                @map("account_reference")
  description              String?                @map("description")
  providerReceiptNumber    String?                @map("provider_receipt_number")
  providerResponseCode     String?                @map("provider_response_code")
  providerResponseDescription String?             @map("provider_response_description")
  providerCallback         Json?                  @map("provider_callback")
  processedAt              DateTime?              @map("processed_at")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")
  wallet                   Wallet?                @relation(fields: [walletId], references: [id], onDelete: SetNull)
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([walletId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("wallet_transactions")
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @db.Uuid @map("user_id")
  audience      NotificationAudience @default(USER)
  type          NotificationType     @default(SYSTEM)
  title         String
  message       String
  transactionId String?              @db.Uuid @map("transaction_id")
  amount        Int?
  balance       Int?
  mpesaCode     String?              @map("mpesa_code")
  isRead        Boolean              @default(false) @map("is_read")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([audience, isRead])
  @@index([createdAt])
  @@index([transactionId])
  @@unique([userId, transactionId, type, audience])
  @@map("notifications")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  tokenHash  String   @map("token_hash")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}
