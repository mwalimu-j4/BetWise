generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(uuid()) @db.Uuid
  fullName      String?              @map("full_name")
  email         String               @unique
  phone         String               @unique
  passwordHash  String               @map("password_hash")
  isVerified    Boolean              @default(false) @map("is_verified")
  accountStatus AccountStatus        @default(ACTIVE) @map("account_status")
  bannedAt      DateTime?            @map("banned_at")
  role          UserRole             @default(USER)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  bets          Bet[]
  notifications Notification[]
  resetTokens   PasswordResetToken[]
  refreshTokens RefreshToken[]
  transactions  WalletTransaction[]
  wallet        Wallet?

  @@map("users")
}

model Wallet {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @unique @map("user_id") @db.Uuid
  balance      Int                 @default(0) @map("balance")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id                          String                  @id @default(uuid()) @db.Uuid
  userId                      String                  @map("user_id") @db.Uuid
  walletId                    String?                 @map("wallet_id") @db.Uuid
  type                        WalletTransactionType
  status                      WalletTransactionStatus @default(PENDING)
  amount                      Int
  currency                    String                  @default("KES")
  channel                     String
  reference                   String                  @unique
  checkoutRequestId           String?                 @unique @map("checkout_request_id")
  merchantRequestId           String?                 @unique @map("merchant_request_id")
  phone                       String?                 @map("phone")
  accountReference            String?                 @map("account_reference")
  description                 String?                 @map("description")
  providerReceiptNumber       String?                 @map("provider_receipt_number")
  providerResponseCode        String?                 @map("provider_response_code")
  providerResponseDescription String?                 @map("provider_response_description")
  providerCallback            Json?                   @map("provider_callback")
  processedAt                 DateTime?               @map("processed_at")
  createdAt                   DateTime                @default(now()) @map("created_at")
  updatedAt                   DateTime                @updatedAt @map("updated_at")
  user                        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet                      Wallet?                 @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("wallet_transactions")
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @map("user_id") @db.Uuid
  audience      NotificationAudience @default(USER)
  type          NotificationType     @default(SYSTEM)
  title         String
  message       String
  transactionId String?              @map("transaction_id") @db.Uuid
  amount        Int?
  balance       Int?
  mpesaCode     String?              @map("mpesa_code")
  isRead        Boolean              @default(false) @map("is_read")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, transactionId, type, audience])
  @@index([userId])
  @@index([audience, isRead])
  @@index([createdAt])
  @@index([transactionId])
  @@map("notifications")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model SportEvent {
  id             String          @id @default(uuid()) @db.Uuid
  eventId        String          @unique @map("event_id")
  leagueId       String?         @map("league_id")
  leagueName     String?         @map("league_name")
  sportKey       String?         @map("sport_key")
  homeTeam       String          @map("home_team")
  awayTeam       String          @map("away_team")
  commenceTime   DateTime        @map("commence_time")
  status         EventStatus     @default(UPCOMING)
  homeScore      Int?            @map("home_score")
  awayScore      Int?            @map("away_score")
  rawData        Json?           @map("raw_data")
  isActive       Boolean         @default(false) @map("is_active")
  houseMargin    Float           @default(0) @map("house_margin")
  marketsEnabled String[]        @default(["h2h"]) @map("markets_enabled")
  fetchedAt      DateTime        @default(now()) @map("fetched_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  bets           Bet[]
  displayedOdds  DisplayedOdds[]
  odds           EventOdds[]

  @@index([status])
  @@index([commenceTime])
  @@index([sportKey])
  @@index([isActive])
  @@map("sport_events")
}

model EventOdds {
  id            String     @id @default(uuid()) @db.Uuid
  eventId       String     @map("event_id")
  bookmakerId   String     @map("bookmaker_id")
  bookmakerName String     @map("bookmaker_name")
  marketType    String     @map("market_type")
  side          String
  decimalOdds   Float      @map("decimal_odds")
  recordedAt    DateTime   @default(now()) @map("recorded_at")
  event         SportEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([eventId])
  @@index([bookmakerId])
  @@map("event_odds")
}

model DisplayedOdds {
  id            String     @id @default(uuid()) @db.Uuid
  eventId       String     @map("event_id")
  bookmakerId   String     @map("bookmaker_id")
  bookmakerName String     @map("bookmaker_name")
  marketType    String     @map("market_type")
  side          String
  rawOdds       Float      @map("raw_odds")
  displayOdds   Float      @map("display_odds")
  isVisible     Boolean    @default(true) @map("is_visible")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  event         SportEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, bookmakerId, marketType, side])
  @@index([eventId])
  @@index([isVisible])
  @@map("displayed_odds")
}

model Bet {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  eventId         String     @map("event_id")
  bookmakerId     String?    @map("bookmaker_id")
  marketType      String     @map("market_type")
  side            String
  stake           Float
  displayOdds     Float      @map("display_odds")
  potentialPayout Float      @map("potential_payout")
  status          BetStatus  @default(PENDING)
  placedAt        DateTime   @default(now()) @map("placed_at")
  settledAt       DateTime?  @map("settled_at")
  event           SportEvent @relation(fields: [eventId], references: [eventId])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([placedAt])
  @@map("bets")
}

model AdminSettings {
  key       String   @id @default("global")
  config    Json
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_settings")
}

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_STAKE
  BET_WIN
  REFUND
  BONUS
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum NotificationAudience {
  USER
  ADMIN
}

enum NotificationType {
  DEPOSIT_SUCCESS
  DEPOSIT_FAILED
  WITHDRAWAL_SUCCESS
  WITHDRAWAL_FAILED
  SYSTEM
}

enum EventStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}
