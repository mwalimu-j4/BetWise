generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_STAKE
  BET_WIN
  REFUND
  BONUS
}

enum WalletTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum NotificationAudience {
  USER
  ADMIN
}

enum NotificationType {
  DEPOSIT_SUCCESS
  DEPOSIT_FAILED
  WITHDRAWAL_SUCCESS
  WITHDRAWAL_FAILED
  BET_WON
  BET_LOST
  BET_VOID
  EVENT_ENDED
  SYSTEM
}

enum EventStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

enum BetAuditAction {
  UPDATE_BLOCKED
  CANCEL_ATTEMPT
  CANCEL_SUCCESS
  CANCEL_BLOCKED
  INTEGRITY_ERROR
}

enum ContactStatus {
  SUBMITTED
  READ
  RESOLVED
}

enum RiskAlertType {
  HIGH_RISK_BET
  EXPOSURE_LIMIT_EXCEEDED
  SUSPICIOUS_PATTERN
  RAPID_ACCOUNT_ACTIVITY
  UNUSUAL_ODDS_MOVEMENT
  SELF_EXCLUSION_BREACH
  DUPLICATE_ACCOUNT
  FRAUD_INDICATOR
  BLACKLIST_MATCH
  CUSTOM_RULE_VIOLATION
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  IN_REVIEW
  ESCALATED
  RESOLVED
  DISMISSED
}

enum BanAppealStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model User {
  id            String               @id @default(uuid()) @db.Uuid
  fullName      String?              @map("full_name")
  email         String               @unique
  phone         String               @unique
  passwordHash  String               @map("password_hash")
  mustChangePassword Boolean         @default(true) @map("must_change_password")
  isVerified    Boolean              @default(false) @map("is_verified")
  accountStatus AccountStatus        @default(ACTIVE) @map("account_status")
  adminTotpEnabled Boolean           @default(false) @map("admin_totp_enabled")
  adminTotpSecret  String?           @map("admin_totp_secret")
  bannedAt      DateTime?            @map("banned_at")
  banReason     String?              @map("ban_reason")
  role          UserRole             @default(USER)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  wallet        Wallet?
  bets          Bet[]
  notifications Notification[]
  resetTokens   PasswordResetToken[]
  refreshTokens RefreshToken[]
  transactions  WalletTransaction[]
  betAuditLogs  BetAuditLog[]
  riskAlerts    RiskAlert[]
  contacts      Contact[]
  banAppeals    BanAppeal[]
  adminLoginChallenges AdminLoginChallenge[]

  @@map("users")
}

model BanAppeal {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  appealText      String              @map("appeal_text")
  status          BanAppealStatus     @default(PENDING)
  responseText    String?             @map("response_text")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  reviewedAt      DateTime?           @map("reviewed_at")
  reviewedBy      String?             @map("reviewed_by")
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("ban_appeals")
}

model Wallet {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @unique @map("user_id") @db.Uuid
  balance      Int                 @default(0) @map("balance")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id                          String                  @id @default(uuid()) @db.Uuid
  userId                      String                  @map("user_id") @db.Uuid
  walletId                    String?                 @map("wallet_id") @db.Uuid
  type                        WalletTransactionType
  status                      WalletTransactionStatus @default(PENDING)
  amount                      Int
  currency                    String                  @default("KES")
  channel                     String
  reference                   String                  @unique
  checkoutRequestId           String?                 @unique @map("checkout_request_id")
  merchantRequestId           String?                 @unique @map("merchant_request_id")
  phone                       String?                 @map("phone")
  accountReference            String?                 @map("account_reference")
  description                 String?                 @map("description")
  providerReceiptNumber       String?                 @map("provider_receipt_number")
  providerResponseCode        String?                 @map("provider_response_code")
  providerResponseDescription String?                 @map("provider_response_description")
  providerCallback            Json?                   @map("provider_callback")
  processedAt                 DateTime?               @map("processed_at")
  createdAt                   DateTime                @default(now()) @map("created_at")
  updatedAt                   DateTime                @updatedAt @map("updated_at")
  user                        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet                      Wallet?                 @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("wallet_transactions")
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @map("user_id") @db.Uuid
  audience      NotificationAudience @default(USER)
  type          NotificationType     @default(SYSTEM)
  title         String
  message       String
  transactionId String?              @map("transaction_id") @db.Uuid
  amount        Int?
  balance       Int?
  mpesaCode      String?              @map("mpesa_code")
  isRead        Boolean              @default(false) @map("is_read")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, transactionId, type, audience])
  @@index([userId])
  @@index([audience, isRead])
  @@index([createdAt])
  @@index([transactionId])
  @@map("notifications")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AdminLoginChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  challengeHash String  @unique @map("challenge_hash")
  otpHash      String   @map("otp_hash")
  expiresAt    DateTime @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  attempts     Int      @default(0)
  ipAddress    String?  @map("ip_address")
  deviceInfo   String?  @map("device_info")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_login_challenges")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model SportEvent {
  id             String        @id @default(uuid()) @db.Uuid
  eventId        String        @unique @map("event_id")
  leagueId       String?       @map("league_id")
  leagueName     String?       @map("league_name")
  sportKey       String?       @map("sport_key")
  homeTeam       String        @map("home_team")
  awayTeam       String        @map("away_team")
  commenceTime   DateTime      @map("commence_time")
  status         EventStatus   @default(UPCOMING)
  homeScore      Int?          @map("home_score")
  awayScore      Int?          @map("away_score")
  rawData        Json?         @map("raw_data")
  isActive       Boolean       @default(false) @map("is_active")
  houseMargin    Float         @default(0) @map("house_margin")
  marketsEnabled String[]      @default(["h2h"]) @map("markets_enabled")
  fetchedAt      DateTime      @default(now()) @map("fetched_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  odds           EventOdds[]
  displayedOdds  DisplayedOdds[]
  bets           Bet[]

  @@index([status])
  @@index([commenceTime])
  @@index([sportKey])
  @@index([isActive])
  @@map("sport_events")
}

model EventOdds {
  id            String    @id @default(uuid()) @db.Uuid
  eventId       String    @map("event_id")
  bookmakerId   String    @map("bookmaker_id")
  bookmakerName String    @map("bookmaker_name")
  marketType    String    @map("market_type")
  side          String
  decimalOdds   Float     @map("decimal_odds")
  recordedAt    DateTime  @default(now()) @map("recorded_at")
  event         SportEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([eventId])
  @@index([bookmakerId])
  @@map("event_odds")
}

model DisplayedOdds {
  id            String    @id @default(uuid()) @db.Uuid
  eventId       String    @map("event_id")
  bookmakerId   String    @map("bookmaker_id")
  bookmakerName String    @map("bookmaker_name")
  marketType    String    @map("market_type")
  side          String
  rawOdds       Float     @map("raw_odds")
  displayOdds   Float     @map("display_odds")
  isVisible     Boolean   @default(true) @map("is_visible")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  event         SportEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, bookmakerId, marketType, side])
  @@index([eventId])
  @@index([isVisible])
  @@map("displayed_odds")
}

model Bet {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  eventId            String        @map("event_id")
  bookmakerId        String?       @map("bookmaker_id")
  betCode            String        @unique @map("bet_code")
  betType            String        @default("NORMAL") @map("bet_type")
  marketType         String        @map("market_type")
  side               String
  isPromoted         Boolean       @default(false) @map("is_promoted")
  selectionsSnapshot Json?         @map("selections_snapshot")
  stake              Float
  displayOdds        Float         @map("display_odds")
  potentialPayout    Float         @map("potential_payout")
  status             BetStatus     @default(PENDING)
  placedAt           DateTime      @default(now()) @map("placed_at")
  settledAt          DateTime?     @map("settled_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancelReason       String?       @map("cancel_reason")
  lastStatusChangeAt DateTime      @default(now()) @map("last_status_change_at")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event              SportEvent    @relation(fields: [eventId], references: [eventId])
  auditLogs          BetAuditLog[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([placedAt])
  @@index([userId, status])
  @@index([userId, placedAt(sort: Desc)])
  @@index([eventId, status])
  @@index([placedAt, status])
  @@index([userId, betType, placedAt(sort: Desc)])
  @@map("bets")
}

model BetAuditLog {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid @map("user_id")
  betId         String         @db.Uuid @map("bet_id")
  action        BetAuditAction
  attemptedData Json?          @map("attempted_data")
  ipAddress     String?        @map("ip_address")
  createdAt     DateTime       @default(now()) @map("created_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bet           Bet            @relation(fields: [betId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([betId, createdAt(sort: Desc)])
  @@map("bet_audit_log")
}

model AdminSettings {
  key                             String   @id @default("global")
  platformName                    String   @default("BetWise") @map("platform_name")
  environment                     String   @default("sandbox")
  defaultCurrency                 String   @default("KES") @map("default_currency")
  timezone                        String   @default("Africa/Nairobi")
  maintenanceMode                 Boolean  @default(false) @map("maintenance_mode")
  registrationEnabled             Boolean  @default(true) @map("registration_enabled")
  minDeposit                      Int      @default(100) @map("min_deposit")
  maxDeposit                      Int      @default(200000) @map("max_deposit")
  minWithdrawal                   Int      @default(100) @map("min_withdrawal")
  maxWithdrawal                   Int      @default(100000) @map("max_withdrawal")
  dailyTransactionLimit           Int      @default(500000) @map("daily_transaction_limit")
  maxActiveBetsPerUser            Int      @default(60) @map("max_active_bets_per_user")
  defaultUserRole                 String   @default("USER") @map("default_user_role")
  kycRequired                     Boolean  @default(true) @map("kyc_required")
  kycRequireId                    Boolean  @default(true) @map("kyc_require_id")
  kycRequirePhone                 Boolean  @default(true) @map("kyc_require_phone")
  kycRequireEmail                 Boolean  @default(true) @map("kyc_require_email")
  withdrawalRequiresKyc           Boolean  @default(true) @map("withdrawal_requires_kyc")
  minimumAge                      Int      @default(18) @map("minimum_age")
  allowedCountries                String[] @default(["KE"]) @map("allowed_countries")
  paymentMpesaEnabled             Boolean  @default(true) @map("payment_mpesa_enabled")
  paymentBankTransferEnabled      Boolean  @default(false) @map("payment_bank_transfer_enabled")
  mpesaShortcode                  String   @default("174379") @map("mpesa_shortcode")
  mpesaConsumerKey                String   @default("replace-with-consumer-key") @map("mpesa_consumer_key")
  mpesaConsumerSecret             String   @default("replace-with-consumer-secret") @map("mpesa_consumer_secret")
  mpesaPasskey                    String   @default("replace-with-passkey") @map("mpesa_passkey")
  mpesaCallbackUrl                String   @default("") @map("mpesa_callback_url")
  mpesaTransactionFeePercent      Float    @default(15) @map("mpesa_transaction_fee_percent")
  mpesaAutoWithdrawEnabled        Boolean  @default(false) @map("mpesa_auto_withdraw_enabled")
  mpesaWithdrawalApprovalThreshold Int     @default(50000) @map("mpesa_withdrawal_approval_threshold")
  minBetAmount                    Int      @default(10) @map("min_bet_amount")
  maxBetAmount                    Int      @default(200000) @map("max_bet_amount")
  maxWinPerBet                    Int      @default(1000000) @map("max_win_per_bet")
  oddsMarginPercent               Float    @default(7) @map("odds_margin_percent")
  betDelayMs                      Int      @default(1500) @map("bet_delay_ms")
  cashoutEnabled                  Boolean  @default(true) @map("cashout_enabled")
  cashoutMarginPercent            Float    @default(5) @map("cashout_margin_percent")
  allowLiveBetting                Boolean  @default(true) @map("allow_live_betting")
  maxExposurePerEvent             Int      @default(2000000) @map("max_exposure_per_event")
  maxExposurePerMarket            Int      @default(800000) @map("max_exposure_per_market")
  maxPayoutPerDay                 Int      @default(8000000) @map("max_payout_per_day")
  highRiskBetThreshold            Int      @default(250000) @map("high_risk_bet_threshold")
  autoBlockSuspiciousUsers        Boolean  @default(true) @map("auto_block_suspicious_users")
  welcomeBonusEnabled             Boolean  @default(true) @map("welcome_bonus_enabled")
  bonusMode                       String   @default("percentage") @map("bonus_mode")
  bonusAmount                     Int      @default(500) @map("bonus_amount")
  bonusPercent                    Float    @default(100) @map("bonus_percent")
  wageringRequirementMultiplier   Float    @default(3) @map("wagering_requirement_multiplier")
  bonusExpiryHours                Int      @default(168) @map("bonus_expiry_hours")
  maxBonusPerUser                 Int      @default(3000) @map("max_bonus_per_user")
  cashbackRule                    String   @default("5% cashback for net losses above KES 2,000, credited weekly.") @map("cashback_rule")
  smsEnabled                      Boolean  @default(true) @map("sms_enabled")
  emailEnabled                    Boolean  @default(true) @map("email_enabled")
  notifyDepositSuccess            Boolean  @default(true) @map("notify_deposit_success")
  notifyWithdrawalSuccess         Boolean  @default(true) @map("notify_withdrawal_success")
  notifyBetPlaced                 Boolean  @default(false) @map("notify_bet_placed")
  notifyBetResult                 Boolean  @default(true) @map("notify_bet_result")
  notifyAdminAlerts               Boolean  @default(true) @map("notify_admin_alerts")
  adminWithdrawalSoundEnabled     Boolean  @default(true) @map("admin_withdrawal_sound_enabled")
  adminWithdrawalSoundTone        String   @default("/sounds/universfield-new-notification-010-352755.mp3") @map("admin_withdrawal_sound_tone")
  adminWithdrawalSoundVolume      Int      @default(80) @map("admin_withdrawal_sound_volume")
  sportsApiKey                    String   @default("replace-with-sports-api-key") @map("sports_api_key")
  oddsProviderName                String   @default("TheOddsAPI") @map("odds_provider_name")
  primaryWebhookUrl               String   @default("https://example.com/webhooks/sports") @map("primary_webhook_url")
  fallbackWebhookUrl              String   @default("https://example.com/webhooks/sports/fallback") @map("fallback_webhook_url")
  retryAttempts                   Int      @default(3) @map("retry_attempts")
  retryBackoffMs                  Int      @default(5000) @map("retry_backoff_ms")
  requestsPerMinute               Int      @default(600) @map("requests_per_minute")
  adminTwoFactorRequired          Boolean  @default(true) @map("admin_two_factor_required")
  passwordMinLength               Int      @default(8) @map("password_min_length")
  requireUppercase                Boolean  @default(true) @map("require_uppercase")
  requireNumber                   Boolean  @default(true) @map("require_number")
  requireSpecialChar              Boolean  @default(true) @map("require_special_char")
  sessionTimeoutMinutes           Int      @default(60) @map("session_timeout_minutes")
  maxLoginAttempts                Int      @default(5) @map("max_login_attempts")
  ipWhitelist                     String[] @default([]) @map("ip_whitelist")
  ipBlacklist                     String[] @default([]) @map("ip_blacklist")
  winningsTaxPercent              Float    @default(20) @map("winnings_tax_percent")
  depositTaxPercent               Float    @default(0) @map("deposit_tax_percent")
  commissionPercent               Float    @default(2) @map("commission_percent")
  roundingRule                    String   @default("nearest_1") @map("rounding_rule")
  affiliateCommissionPercent      Float    @default(5) @map("affiliate_commission_percent")
  multiLevelReferralsEnabled      Boolean  @default(false) @map("multi_level_referrals_enabled")
  affiliateMinimumPayoutThreshold Int      @default(1500) @map("affiliate_minimum_payout_threshold")
  affiliateWithdrawalRule         String   @default("Monthly payouts after reconciliation and KYC check.") @map("affiliate_withdrawal_rule")
  termsAndConditions              String   @default("By using this platform, you agree to our betting terms, fair usage policies, and anti-fraud controls.") @map("terms_and_conditions")
  privacyPolicy                   String   @default("We process account and transactional data strictly for service operations, regulatory compliance, and fraud prevention.") @map("privacy_policy")
  responsibleGamblingMessage      String   @default("Bet responsibly. Set limits and seek support if betting affects your wellbeing.") @map("responsible_gambling_message")
  supportContactInfo              String   @default("support@betwise.co.ke | +254700000000") @map("support_contact_info")
  updatedBy                       String?  @map("updated_by")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  @@map("admin_settings")
}

model RiskAlert {
  id             String        @id @default(uuid()) @db.Uuid
  alertType      RiskAlertType
  severity       RiskSeverity  @default(MEDIUM)
  status         AlertStatus   @default(OPEN)
  description    String
  userId         String?       @map("user_id") @db.Uuid
  betId          String?       @map("bet_id") @db.Uuid
  eventId        String?       @map("event_id")
  triggeredValue Float?        @map("triggered_value")
  threshold      Float?
  details        Json?
  actionTaken    String?       @map("action_taken")
  resolvedAt     DateTime?     @map("resolved_at")
  resolvedBy     String?       @map("resolved_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("risk_alerts")
}

model Contact {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  fullName  String        @map("full_name")
  phone     String
  subject   String
  message   String
  status    ContactStatus @default(SUBMITTED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([phone])
  @@map("contacts")
}

model NewsletterSubscription {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([isActive])
  @@index([subscribedAt])
  @@map("newsletter_subscriptions")
}

enum CustomEventStatus {
  DRAFT
  PUBLISHED
  LIVE
  SUSPENDED
  FINISHED
  CANCELLED
}

enum CustomMarketStatus {
  OPEN
  SUSPENDED
  CLOSED
  SETTLED
}

enum CustomSelectionResult {
  PENDING
  WIN
  LOSE
  VOID
}

enum CustomBetStatus {
  PENDING
  WON
  LOST
  VOID
  CANCELLED
}

model CustomEvent {
  id            String              @id @default(uuid()) @db.Uuid
  title         String
  teamHome      String              @map("team_home")
  teamAway      String              @map("team_away")
  category      String              @default("Football")
  league        String              @default("Custom League")
  startTime     DateTime            @map("start_time")
  endTime       DateTime?           @map("end_time")
  status        CustomEventStatus   @default(DRAFT)
  description   String?
  bannerUrl     String?             @map("banner_url")
  createdBy     String              @map("created_by") @db.Uuid
  publishedAt   DateTime?           @map("published_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  markets       CustomMarket[]
  bets          CustomBet[]
  auditLogs     CustomEventAuditLog[]

  @@index([status])
  @@index([startTime])
  @@index([status, startTime])
  @@index([createdBy])
  @@index([createdAt])
  @@map("custom_events")
}

model CustomMarket {
  id          String              @id @default(uuid()) @db.Uuid
  eventId     String              @map("event_id") @db.Uuid
  event       CustomEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  status      CustomMarketStatus  @default(OPEN)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  selections  CustomSelection[]

  @@index([eventId])
  @@index([status])
  @@map("custom_markets")
}

model CustomSelection {
  id          String                @id @default(uuid()) @db.Uuid
  marketId    String                @map("market_id") @db.Uuid
  market      CustomMarket          @relation(fields: [marketId], references: [id], onDelete: Cascade)
  label       String
  name        String
  odds        Float
  result      CustomSelectionResult @default(PENDING)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  bets        CustomBet[]

  @@index([marketId])
  @@map("custom_selections")
}

model CustomBet {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  eventId       String          @map("event_id") @db.Uuid
  event         CustomEvent     @relation(fields: [eventId], references: [id])
  selectionId   String          @map("selection_id") @db.Uuid
  selection     CustomSelection @relation(fields: [selectionId], references: [id])
  stake         Float
  odds          Float
  potentialWin  Float           @map("potential_win")
  status        CustomBetStatus @default(PENDING)
  placedAt      DateTime        @default(now()) @map("placed_at")
  settledAt     DateTime?       @map("settled_at")

  @@index([userId])
  @@index([eventId])
  @@index([selectionId])
  @@index([status])
  @@index([placedAt])
  @@map("custom_bets")
}

model CustomEventAuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  eventId       String      @map("event_id") @db.Uuid
  event         CustomEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  adminId       String      @map("admin_id") @db.Uuid
  action        String
  previousValue String?     @map("previous_value")
  newValue      String?     @map("new_value")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([eventId])
  @@index([adminId])
  @@index([createdAt])
  @@map("custom_event_audit_logs")
}

model SportCategory {
  id            String              @id @default(uuid()) @db.Uuid
  sportKey      String              @unique @map("sport_key")
  displayName   String              @map("display_name")
  apiSportId    String?             @map("api_sport_id")
  icon          String              @default("🎯")
  isActive      Boolean             @default(false) @map("is_active")
  showInNav     Boolean             @default(true) @map("show_in_nav")
  sortOrder     Int                 @default(0) @map("sort_order")
  eventCount    Int                 @default(0) @map("event_count")
  lastSyncedAt  DateTime?           @map("last_synced_at")
  configuredBy  String?             @map("configured_by") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  configLogs    CategoryConfigLog[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("sport_categories")
}

model CategoryConfigLog {
  id               String         @id @default(uuid()) @db.Uuid
  sportKey         String         @map("sport_key")
  adminId          String         @map("admin_id") @db.Uuid
  eventsConfigured Int            @map("events_configured")
  action           String
  createdAt        DateTime       @default(now()) @map("created_at")
  category         SportCategory  @relation(fields: [sportKey], references: [sportKey])

  @@index([sportKey])
  @@index([adminId])
  @@index([createdAt])
  @@map("category_config_logs")
}
